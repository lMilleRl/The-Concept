  m_Script: {fileID: 11500000, guid: 0e01bca1f4120f24eaacdc9485371764, type: 3}
  m_Name: Rock
  m_EditorClassIdentifier: 
  _ownText: "This fist-sized stone does not gleam. It does not warm to the touch,
    nor does it hum with obvious magic. At first glance, it is a mistake\u2014a lump
    of unremarkable gray sediment, pitted and scarred as if it had been chewed by
    time itself. But when the light shifts, or when you are not quite looking at
    it, a faint, internal shimmer pulses from its core. Like a dying star seen through
    murky water. Like a memory of a feeling you forgot you had."
  _fontSize: 72
  _textAppearDuration: 2
  _easeTextTweenType: 0
