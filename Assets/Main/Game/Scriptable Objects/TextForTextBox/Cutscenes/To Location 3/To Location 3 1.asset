  m_Script: {fileID: 11500000, guid: 0e01bca1f4120f24eaacdc9485371764, type: 3}
  m_Name: To Location 3 1
  m_EditorClassIdentifier: 
  _ownText: "Above \u2014 a frozen, leaden sky.  Concrete towers, half-collapsed. 
    Tanks. Trains. Rusted. Motionless.  Snow buries the ground.  Far ahead \u2014
    the device. Pulsing. Suit compensating for cold.  Signal strong. Device close."
  _fontSize: 72
  _textAppearDuration: 5
  _easeTextTweenType: 1
